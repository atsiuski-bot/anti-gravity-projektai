rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to get user data - with safety check
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper to check if user is not disabled - safe version
    // Uses `!= true` which passes for both `false` and missing/null fields,
    // so legacy user documents without an `isDisabled` field still work.
    function isUserActive() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isDisabled != true;
    }

    // Helper to check user role
    function isAdmin() {
      return isUserActive() && 
             (getUserData().role == 'admin' ||
              getUserData().role == 'Administratorius');
    }

    function isManager() {
      return isUserActive() && 
             getUserData().role == 'manager';
    }

    function isManagerOrAdmin() {
      return isAdmin() || isManager();
    }

    // USERS - Allow authenticated users to read user documents (needed for AuthContext and viewing coworkers)
    match /users/{userId} {
      // Allow authenticated users to read user data (needed for viewing coworker info, calendars, etc.)
      allow read: if isAuthenticated();
      // Users can create their own document on first login
      allow create: if isAuthenticated() && request.auth.uid == userId; 
      // Update: users can update their own doc (but not change role or isDisabled).
      // Managers/admins can update any user. Only admins can change roles.
      // The isDisabled guard uses `get()` with a fallback so legacy documents
      // that lack the field entirely don't block normal profile updates.
      allow update: if isAuthenticated()
                    && (request.auth.uid == userId || isManagerOrAdmin())
                    && (isAdmin() || request.resource.data.role == resource.data.role)
                    && (isManagerOrAdmin() || 
                        request.resource.data.isDisabled == resource.data.get('isDisabled', false));
      allow delete: if isAdmin();
    }

    // TASKS
    match /tasks/{taskId} {
      allow read, write: if isUserActive();
    }

    // SHIFT LOGS (New)
    match /shift_logs/{logId} {
      allow read, write: if isUserActive();
    }

    // WORK SESSIONS
    match /work_sessions/{sessionId} {
      allow read, write: if isUserActive();
    }

    // BREAK SESSIONS
    match /break_sessions/{sessionId} {
      allow read, write: if isUserActive();
    }

    // DAILY STATS
    match /daily_stats/{statId} {
      allow read, write: if isUserActive();
    }

    // WORK HOURS (Planner)
    match /work_hours/{docId} {
      allow read, write: if isUserActive();
    }

    // ARCHIVED TASKS
    match /archived_tasks/{taskId} {
      allow read, write: if isUserActive();
    }

    // DELETED TASKS
    match /deleted_tasks/{taskId} {
      allow read, write: if isUserActive();
    }

    // NOTIFICATIONS
    match /calendar_notifications/{notifId} {
      allow read, write: if isUserActive();
    }

    // CALENDAR REQUESTS (Approval workflow)
    match /calendar_requests/{requestId} {
      allow read, write: if isUserActive();
    }

    // REQUEST NOTIFICATIONS (Task approval requests)
    match /request_notifications/{notifId} {
      allow read, write: if isUserActive();
    }

    // TASK TEMPLATES
    match /task_templates/{templateId} {
      allow read, write: if isUserActive();
    }

    // USER SETTINGS
    match /user_settings/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ERROR LOGS (durable crash log)
    // Any authenticated user may APPEND a crash report (kept permissive so a broken
    // session can still record its failure); only managers/admins may read them.
    // Entries are immutable; only admins may clear them.
    match /error_logs/{logId} {
      allow create: if isAuthenticated();
      allow read:   if isManagerOrAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
