rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Identity / role helpers -------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Active = authenticated, the user doc exists, and isDisabled is not true.
    // We read the field with .get('isDisabled', false) — NOT dot notation. In
    // Firestore rules, accessing a MISSING map key with `.field` raises an
    // evaluation error that denies the rule; only .get(key, default) is safe for an
    // absent field. Legacy user docs created before the isDisabled convention have
    // no such field, so dot access there silently denied EVERY team-wide read for
    // those users (their own-doc reads still passed via the uid match, so the app
    // shell rendered while every collection listener failed permission-denied).
    // The default `false` => a missing field is treated as "not disabled" = active.
    // (Repeated get()/exists() on the same user doc are cached within one rule
    // evaluation, so the role helpers below add no extra document-read cost.)
    function isUserActive() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isDisabled', false) != true;
    }

    function isAdmin() {
      return isUserActive() &&
             (getUserData().get('role', '') == 'admin' ||
              getUserData().get('role', '') == 'Administratorius');
    }

    function isManager() {
      return isUserActive() &&
             getUserData().get('role', '') == 'manager';
    }

    // Vyr. vadovas (senior manager): a manager-shaped rank SCOPED to its transitive subtree — its
    // assigned managers plus those managers' workers (ADR 0007), NOT the whole company. Account
    // management (role changes, membership) stays admin-only.
    // Four-level hierarchy: admin > seniorManager > manager > worker.
    function isSeniorManager() {
      return isUserActive() &&
             getUserData().get('role', '') == 'seniorManager';
    }

    function isManagerOrAdmin() {
      return isAdmin() || isManager() || isSeniorManager();
    }

    // ---- Scoped overseer hierarchy (ADR 0005 + ADR 0007) -------------------
    // A manager is "scoped" when an admin set scopedManager=true on their user doc: they may only
    // SEE and ACT on their assigned people. A SENIOR manager (Vyr. vadovas) is ALWAYS scoped — to
    // its transitive subtree (its managers + those managers' workers), denormalized into each row's
    // teamManagerIds closure by a Cloud Function (ADR 0007). Admins and managers left unscoped (the
    // default) keep whole-company access.
    function isScopedManager() {
      return isManager() && getUserData().get('scopedManager', false) == true;
    }
    // A caller whose visibility is limited to their subtree's denormalized stamp (the row's
    // teamManagerIds closure): a scoped manager OR any senior manager. Both rely on inCallerTeam().
    function isScopedOverseer() {
      return isScopedManager() || isSeniorManager();
    }
    function canSeeWholeTeam() {
      return isAdmin() || (isManager() && getUserData().get('scopedManager', false) != true);
    }
    // The caller is in the target user's OVERSEER CLOSURE (managers + their seniors), maintained on
    // the user doc (overseerIds) by the re-stamp Cloud Function (ADR 0007). One get() on the target
    // doc — used on WRITES only (low volume), so the extra read is acceptable. Used at create/
    // reassign time, before the row's denormalized teamManagerIds has been stamped. Covers BOTH a
    // scoped manager (always in their own workers' closure) and a senior manager.
    function overseesUser(uid) {
      return uid is string &&
             exists(/databases/$(database)/documents/users/$(uid)) &&
             request.auth.uid in get(/databases/$(database)/documents/users/$(uid)).data.get('overseerIds', []);
    }
    // The EXISTING row is within the caller's team (denormalized teamManagerIds copied from the
    // owner). Pure field compare — no extra read — so it is cheap on the hot read path.
    function inCallerTeam() {
      return request.auth.uid in resource.data.get('teamManagerIds', []);
    }
    // A private row (task/session) is readable by: whole-team viewers, its owner, the caller's
    // team membership, or (tasks only) the manager/auditor named on the row.
    function canReadOwnedTask() {
      return canSeeWholeTeam() ||
             ownsAssignedUser() ||
             inCallerTeam() ||
             request.auth.uid == resource.data.get('managerId', '');
    }

    // The WRITE-side mirror of the managerId branch in canReadOwnedTask: a manager/admin who is the
    // task's DESIGNATED vadovas (managerId) or auditor (taskAuditor) may act on it (approve / accept /
    // edit / delete) even when it sits OUTSIDE their team closure — e.g. ANOTHER manager created the
    // task and named THIS manager its overseer. Without this, such a manager could SEE the task (READ
    // grants managerId) yet have every WRITE silently denied — the exact "I'm the vadovas but can
    // neither approve nor edit" trap (founder, 2026-06-24). Because the named manager IS the legitimate
    // approver, this branch deliberately permits the approval-field flip that changesApprovalFields()
    // blocks on the assignee branch. Gated to a manager role for defense in depth, so a stray worker
    // uid sitting in managerId can never gain write. Reads resource.data, so UPDATE/DELETE only.
    function isNamedTaskOverseer() {
      return isManagerOrAdmin() &&
             (request.auth.uid == resource.data.get('managerId', '') ||
              request.auth.uid == resource.data.get('taskAuditor', ''));
    }

    // ---- Per-document ownership helpers -------------------------------------
    // A worker "owns" a record when its owner field equals their uid. The owner
    // field per collection was audited from the client write sites: `userId` for
    // sessions/hours/calendar/notifications, `assignedUserId` for tasks,
    // `recipientId` for request_notifications, `createdBy` for templates.
    // Read/update/delete use resource.data (the stored doc); create uses
    // request.resource.data (the incoming doc).
    //
    // READ vs WRITE asymmetry (important — Firestore rules are NOT row filters):
    // several worker-facing features (the Reports tab, the team calendar) issue
    // collection-WIDE queries and filter client-side, so they intentionally read
    // other users' rows. A per-owner READ rule would make those whole queries fail
    // with permission-denied (one unreadable row rejects the entire query). This
    // app's design is team-wide VISIBILITY, so READ on the shared collections stays
    // broad (`isUserActive()`). The real threat C1 identified is TAMPERING, so
    // WRITE (create/update/delete) is scoped to the owner with a manager/admin
    // escape — a worker can see a colleague's hours but cannot mutate them. If
    // per-user read isolation is ever wanted, it requires changing those client
    // queries to filter by uid for workers (a product change), not just the rule.

    function ownsUserId() {
      return resource.data.userId == request.auth.uid;
    }
    function createOwnsUserId() {
      return request.resource.data.userId == request.auth.uid;
    }
    function ownsAssignedUser() {
      return resource.data.assignedUserId == request.auth.uid;
    }

    // Manager-only approval/confirmation fields on a task. A worker may edit their
    // own task but must never FLIP these on an existing task (no client-forged
    // self-confirmation of a manager-assigned task). Note: this guards UPDATE only.
    // CREATE is intentionally not guarded this way, because the legitimate call/
    // quick-work auto-logging path creates a worker's own task already 'confirmed'
    // (a call is auto-confirmed by design) — blocking self-confirmed CREATE would
    // break that flow, while the actual escalation risk is flipping an EXISTING task.
    function changesApprovalFields() {
      return (request.resource.data.get('status', '') != resource.data.get('status', '') &&
              request.resource.data.get('status', '') in ['confirmed', 'approved']) ||
             request.resource.data.get('isApproved', false) != resource.data.get('isApproved', false) ||
             request.resource.data.get('confirmedBy', null) != resource.data.get('confirmedBy', null) ||
             request.resource.data.get('approvedBy', null) != resource.data.get('approvedBy', null);
    }

    // ---- Data shape / range validation (durability guardrails) --------------
    // The rules above answer WHO may write; these answer WHAT a write may contain, so a buggy
    // client or a runaway agent cannot poison the logged-time record with impossible values — the
    // failure mode that previously left 247 break_sessions with >960-min durations (a one-off
    // SA-key script had to delete them, because there was no guard at the door).
    //
    // Deliberately PERMISSIVE so it can never break a legitimate flow: a field is checked only when
    // it is PRESENT (the `.get(field, default)` form defaults-pass an absent field) and, on update,
    // only when this write actually CHANGES it. That keeps partial updates (a title rename, a
    // soft-delete that touches no times) and the remediation of an already-corrupt row both
    // possible — neither is blocked by a value it does not set. The admin-SDK Cloud Functions
    // bypass rules entirely, so the team-stamp writes are unaffected.

    // A session's credited duration: a finite number within a physical sanity ceiling (24h). The
    // client clamps far below this (16h), so a legitimate write can never trip it; the ceiling
    // exists only to reject the absurd values that corruption produces.
    function durationInRange(data) {
      return data.get('durationMinutes', 0) is number &&
             data.get('durationMinutes', 0) >= 0 &&
             data.get('durationMinutes', 0) <= 1440;
    }
    // On UPDATE, enforce the range only when the write changes the duration — so a rename /
    // soft-delete (duration untouched) and the cleanup of a pre-existing out-of-range row pass.
    function durationOkForUpdate() {
      return request.resource.data.get('durationMinutes', 0) == resource.data.get('durationMinutes', 0) ||
             durationInRange(request.resource.data);
    }
    // work_hours carries no duration; its time bounds are ISO strings. Guard only that, if present,
    // start/end are strings (a bug writing a number/object/array there is rejected). Absent → pass.
    function workHoursShapeOk(data) {
      return data.get('start', '') is string &&
             data.get('end', '') is string;
    }

    // A task's priority (if present) must be one of the canonical UPPERCASE tokens, and
    // estimatedTimeMinutes (if present) a non-negative number within a sane ceiling (1000h). Mirrors
    // the write-path canonicalization (priority.js / timeUtils) so a future code path cannot
    // re-introduce the priority casing split or a string-typed numeric estimate. Permissive: an
    // ABSENT field passes, so quick-work's minimal shape and legacy rows are never blocked. Applied
    // to /tasks only (NOT /archived_tasks — the client archives legacy rows verbatim).
    function taskFieldsOk(data) {
      return (!('priority' in data) ||
              data.priority in ['URGENT', 'HIGH', 'MEDIUM', 'LOW']) &&
             (!('estimatedTimeMinutes' in data) ||
              (data.estimatedTimeMinutes is number &&
               data.estimatedTimeMinutes >= 0 &&
               data.estimatedTimeMinutes <= 60000));
    }
    // On UPDATE, enforce only when this write CHANGES priority/estimate — so a status/timer/title
    // edit that leaves them untouched, AND the remediation of an already-non-canonical legacy row,
    // both pass. (The app's edit path rewrites priority canonically on every save anyway.)
    function taskFieldsOkForUpdate() {
      return (request.resource.data.get('priority', '') == resource.data.get('priority', '') &&
              request.resource.data.get('estimatedTimeMinutes', 0) == resource.data.get('estimatedTimeMinutes', 0))
             || taskFieldsOk(request.resource.data);
    }

    // ---- USERS --------------------------------------------------------------
    match /users/{userId} {
      // Read OWN doc unconditionally (first-login bootstrap before the doc has an
      // isDisabled value, and a disabled user must still be able to load its own
      // record). Read OTHER users only while ACTIVE — a disabled account keeps a
      // valid token for up to ~1h but can no longer enumerate the whole company.
      allow read: if isAuthenticated() &&
                  (request.auth.uid == userId || isUserActive());
      // Users create their own document on first login.
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Update: own doc or a manager/admin acting on anyone. Only admins change
      // roles; only managers/admins toggle isDisabled (the `get` fallback keeps
      // legacy docs without the field editable).
      // Membership is admin-only: only an admin may change a worker's team (teamManagerIds) or a
      // manager's scope (scopedManager). Otherwise a worker could hide themselves from / expose
      // themselves to a manager, or a scoped manager could lift their own restriction. (ADR 0005)
      // Both the role pin and the isDisabled pin read EVERY operand through .get(field, default).
      // A bare dot access (request.resource.data.isDisabled) on a field the document does NOT carry
      // raises a rules EVALUATION ERROR that denies the whole write — the exact trap isUserActive()
      // documents above. Legacy user docs predate the isDisabled convention, so on a merge update the
      // incoming doc inherits that absence; the previous left-operand dot access therefore denied a
      // worker's own workStatus/activeSession write (every timer action), bricking start/pause/finish
      // for those accounts. Managers/admins were spared only because isManagerOrAdmin() short-circuits
      // the conjunct before the dot access. .get() on both sides defaults a missing field to a safe
      // value so the equality (unchanged on these self-writes) passes for legacy and current docs alike.
      allow update: if isAuthenticated()
                    && (request.auth.uid == userId || isManagerOrAdmin())
                    && (isAdmin() ||
                        request.resource.data.get('role', '') == resource.data.get('role', ''))
                    && (isManagerOrAdmin() ||
                        request.resource.data.get('isDisabled', false) == resource.data.get('isDisabled', false))
                    && (isAdmin() ||
                        request.resource.data.get('teamManagerIds', []) == resource.data.get('teamManagerIds', []))
                    && (isAdmin() ||
                        request.resource.data.get('scopedManager', false) == resource.data.get('scopedManager', false))
                    // Senior-manager membership (which seniors a manager answers to) is admin-only,
                    // exactly like teamManagerIds/scopedManager. (ADR 0007)
                    && (isAdmin() ||
                        request.resource.data.get('seniorManagerIds', []) == resource.data.get('seniorManagerIds', []))
                    && (isAdmin() ||
                        request.resource.data.get('defaultSeniorManager', '') == resource.data.get('defaultSeniorManager', ''))
                    // The overseer closure is written ONLY by the admin-SDK Cloud Function (which
                    // bypasses rules). No client — not even an admin — may hand-edit it, or the
                    // confidentiality boundary could be silently desynced. (ADR 0007)
                    && request.resource.data.get('overseerIds', []) == resource.data.get('overseerIds', [])
                    // Pay rate (tiered NET hourly rates) is admin-only, like team membership — a
                    // worker must never be able to set their own rate. (ADR 0012)
                    && (isAdmin() ||
                        request.resource.data.get('payRate', {}) == resource.data.get('payRate', {}))
                    // Approval-free backdated time-logging is a privilege an admin grants per-user;
                    // it must be admin-only to set, or a worker could self-grant it on one of their
                    // own routine self-writes (workStatus/activeSession). Pinned with .get(...,false)
                    // on BOTH sides so a legacy doc without the field stays editable (the isDisabled
                    // dot-access trap). NOTE: this only gates WHO sets the flag — a worker can already
                    // create their own work_sessions at any timestamp; the flag/UI is the product
                    // gate, the admin notification is the audit trail.
                    && (isAdmin() ||
                        request.resource.data.get('canBackdateTime', false) == resource.data.get('canBackdateTime', false));
      allow delete: if isAdmin();

      // ---- ACHIEVEMENTS (server-awarded, client-immutable) ----------------
      // Earned badges live HERE, not on the user doc — a worker can freely write
      // its OWN /users/{uid} doc (see the update rule above), so storing badges
      // on it would let anyone forge their own. Read is team-wide so peer trophy
      // shelves render for any active member (same broad-read pattern as tasks/
      // sessions). Write is denied to ALL clients incl. the owner: only the Admin
      // SDK (a Cloud Function), which bypasses rules, grants/upgrades a tier.
      match /achievements/{achievementId} {
        allow read: if isUserActive();
        allow write: if false;
      }
    }

    // ---- TASKS --------------------------------------------------------------
    match /tasks/{taskId} {
      // Read: whole-team viewers see all; a scoped manager sees only their team (the row's
      // denormalized teamManagerIds) or tasks they audit; the assignee sees their own. (ADR 0005)
      allow read: if isUserActive() && canReadOwnedTask();
      // Create: a worker self-assigns (covers normal create + call/quick-work auto-logs);
      // whole-team viewers may assign to anyone; a scoped overseer may assign ONLY within their
      // subtree (overseesUser checks the assignee's closure — also covers RESTORE of a team task).
      allow create: if isUserActive() && taskFieldsOk(request.resource.data) && (
                      request.resource.data.assignedUserId == request.auth.uid ||
                      canSeeWholeTeam() ||
                      (isScopedOverseer() && overseesUser(request.resource.data.assignedUserId))
                    );
      // Update: whole-team viewers edit any; the task's named vadovas/auditor edits THEIR task even
      // out of team scope; a scoped manager edits their team's tasks and may only reassign within
      // their team; the assignee edits their own but may NOT flip the manager-only approval fields.
      // taskFieldsOkForUpdate adds the priority/estimate shape guard (enforced only when this write
      // changes those fields).
      allow update: if isUserActive() && taskFieldsOkForUpdate() && (
                      canSeeWholeTeam() ||
                      isNamedTaskOverseer() ||
                      (isScopedOverseer() && inCallerTeam() &&
                        (request.resource.data.assignedUserId == resource.data.assignedUserId ||
                         overseesUser(request.resource.data.assignedUserId))) ||
                      (ownsAssignedUser() && !changesApprovalFields())
                    );
      allow delete: if isUserActive() && (
                      ownsAssignedUser() ||
                      canSeeWholeTeam() ||
                      isNamedTaskOverseer() ||
                      (isScopedOverseer() && inCallerTeam())
                    );
    }

    // ---- SHIFT LOGS (unused collection — locked) ----------------------------
    match /shift_logs/{logId} {
      allow read, write: if false;
    }

    // ---- WORK SESSIONS ------------------------------------------------------
    match /work_sessions/{sessionId} {
      // Read: whole-team viewers see all; a scoped manager only their team; the worker their own.
      allow read:          if isUserActive() && (canSeeWholeTeam() || ownsUserId() || inCallerTeam());
      // Workers log their own; whole-team viewers create time corrections for anyone; a scoped
      // manager only for their people. The duration guard rejects impossible credited time.
      allow create:        if isUserActive() && (
                              createOwnsUserId() ||
                              canSeeWholeTeam() ||
                              (isScopedOverseer() && overseesUser(request.resource.data.userId))
                            ) && durationInRange(request.resource.data);
      // Update carries BOTH guards (composed with &&): the duration guard (main — rejects an
      // impossible credited time, the >960-min corruption vector) AND the userId pin (full-sweep
      // F5 — an owner or whole-team manager may NOT re-point the record to a colleague). Delete is
      // split out because it carries no request.resource to validate.
      allow update:        if isUserActive() && (
                              ownsUserId() ||
                              canSeeWholeTeam() ||
                              (isScopedOverseer() && inCallerTeam())
                            ) && durationOkForUpdate()
                            && request.resource.data.get('userId', '') == resource.data.get('userId', '');
      allow delete:        if isUserActive() && (
                              ownsUserId() ||
                              canSeeWholeTeam() ||
                              (isScopedOverseer() && inCallerTeam())
                            );
    }

    // ---- BREAK SESSIONS -----------------------------------------------------
    match /break_sessions/{sessionId} {
      // Read: whole-team viewers see all; a scoped manager only their team; the worker their own.
      allow read:          if isUserActive() && (canSeeWholeTeam() || ownsUserId() || inCallerTeam());
      // Breaks are self-logged only (no manager-create path). Duration guard (main) — this is the
      // exact collection the >960-min corruption landed in.
      allow create:        if isUserActive() && createOwnsUserId() && durationInRange(request.resource.data);
      // Update carries BOTH guards (composed with &&): the duration guard (main) AND the userId
      // pin (full-sweep F5 — no re-pointing the record to a colleague). Delete is split out
      // because it carries no request.resource to validate.
      allow update:        if isUserActive() && (
                              ownsUserId() ||
                              canSeeWholeTeam() ||
                              (isScopedOverseer() && inCallerTeam())
                            ) && durationOkForUpdate()
                            && request.resource.data.get('userId', '') == resource.data.get('userId', '');
      allow delete:        if isUserActive() && (
                              ownsUserId() ||
                              canSeeWholeTeam() ||
                              (isScopedOverseer() && inCallerTeam())
                            );
    }

    // ---- DAILY STATS (unused collection — locked) ---------------------------
    match /daily_stats/{statId} {
      allow read, write: if false;
    }

    // ---- WORK HOURS (Planner) ----------------------------------------------
    match /work_hours/{docId} {
      // Team-wide read (the team calendar / AllUsersCalendar listens to all hours by
      // date and maps every userId into a whole-team view).
      allow read:          if isUserActive();
      // Workers plan their own hours; whole-team viewers write approved entries for anyone; a
      // scoped overseer (scoped manager / senior manager) only for their people. This scopes the
      // scoped-overseer the way work_sessions/break_sessions/tasks do, so a SCOPED manager cannot
      // write OUTSIDE their subtree here while being correctly scoped everywhere else (ADR 0005/0007)
      // — isManagerOrAdmin() would have let any scoped manager write ANY user's hours.
      //
      // NOTE — why overseesUser() and NOT inCallerTeam(): the sessions/tasks scoped branches lean on
      // each row's denormalized `teamManagerIds` stamp, but work_hours is the ONE owned collection a
      // Cloud Function never stamps (it is absent from functions OWNED_COLLECTIONS and has no
      // stampTeamOn… trigger). inCallerTeam() would therefore always read [] here and silently deny
      // every scoped-overseer write. overseesUser() instead reads the TARGET USER doc's overseerIds
      // closure (one get(), write path only) — the same user-doc check the tasks/sessions CREATE
      // branch uses — so it is correct without any row denormalization. On update/delete it is keyed
      // on the EXISTING owner (resource.data.userId); the create branch keys on the incoming owner.
      // The shape guard rejects a malformed start/end (non-string) so a bug can't poison reports.
      allow create:        if isUserActive() && (
                             createOwnsUserId() ||
                             canSeeWholeTeam() ||
                             (isScopedOverseer() && overseesUser(request.resource.data.userId))
                           ) && workHoursShapeOk(request.resource.data);
      // Update may NOT re-point the record's owner. ownsUserId() only checks the EXISTING
      // owner, so without this pin an owner (or manager) could rewrite userId to a colleague
      // and graft their planned/logged hours onto someone else's record (polluting that
      // person's calendar + reports). Splitting update from delete is required because a
      // delete carries no request.resource to compare. The .get() form tolerates any legacy
      // doc that predates a userId field, matching the defensive idiom used elsewhere here.
      allow update:        if isUserActive() && (
                             ownsUserId() ||
                             canSeeWholeTeam() ||
                             (isScopedOverseer() && overseesUser(resource.data.userId))
                           )
                           && request.resource.data.get('userId', '') == resource.data.get('userId', '')
                           && workHoursShapeOk(request.resource.data);
      allow delete:        if isUserActive() && (
                             ownsUserId() ||
                             canSeeWholeTeam() ||
                             (isScopedOverseer() && overseesUser(resource.data.userId))
                           );
    }

    // ---- ARCHIVED TASKS -----------------------------------------------------
    match /archived_tasks/{taskId} {
      // Read/write scoping mirrors /tasks (ADR 0005): whole-team viewers see/act on all, a scoped
      // manager only on their team, the assignee on their own.
      allow read:   if isUserActive() && canReadOwnedTask();
      allow create: if isUserActive() && (
                      request.resource.data.assignedUserId == request.auth.uid ||
                      canSeeWholeTeam() ||
                      (isScopedOverseer() && overseesUser(request.resource.data.assignedUserId))
                    );
      allow update: if isUserActive() && (
                      canSeeWholeTeam() ||
                      isNamedTaskOverseer() ||
                      (isScopedOverseer() && inCallerTeam() &&
                        (request.resource.data.assignedUserId == resource.data.assignedUserId ||
                         overseesUser(request.resource.data.assignedUserId))) ||
                      (ownsAssignedUser() && !changesApprovalFields())
                    );
      allow delete: if isUserActive() && (
                      ownsAssignedUser() ||
                      canSeeWholeTeam() ||
                      isNamedTaskOverseer() ||
                      (isScopedOverseer() && inCallerTeam())
                    );
    }

    // ---- DELETED TASKS (read-only legacy) -----------------------------------
    // DailyStatistics still opens a collection-wide onSnapshot on this collection,
    // so READ must be allowed (a locked read makes that listener throw permission-
    // denied on every mount). Scoped to the caller's team like the other task collections.
    // Nothing in the client WRITES it (the delete workflow uses archived_tasks), so writes stay
    // locked — the re-stamp Cloud Function uses the admin SDK, which bypasses rules.
    match /deleted_tasks/{taskId} {
      allow read:  if isUserActive() && canReadOwnedTask();
      allow write: if false;
    }

    // ---- SESSIONS (legacy audit log: write-own, manager/admin read) ---------
    // Previously had NO rule, so every write was silently default-denied (the log
    // doc was lost). Allow the owner to append and managers/admins to read it.
    match /sessions/{sessionId} {
      allow create:        if isUserActive() && createOwnsUserId();
      allow read:          if isManagerOrAdmin();
      allow update, delete: if false;
    }

    // ---- CALENDAR NOTIFICATIONS --------------------------------------------
    // Managers monitor every worker's weekly calendar changes; a worker only its
    // own. The worker appends changes (owner update); a manager dismisses.
    match /calendar_notifications/{notifId} {
      allow read:   if isUserActive() &&
                    (resource.data.get('userId', '') == request.auth.uid || isManagerOrAdmin());
      // Worker creates its own; a manager also creates the FIRST notification of a
      // worker's week when approving a calendar change (the audit log carries the
      // worker's userId, not the manager's), so a manager escape is required.
      allow create: if isUserActive() && (createOwnsUserId() || isManagerOrAdmin());
      allow update: if isUserActive() &&
                    (resource.data.get('userId', '') == request.auth.uid || isManagerOrAdmin());
      allow delete: if isManagerOrAdmin();
    }

    // ---- CALENDAR REQUESTS (approval workflow) ------------------------------
    match /calendar_requests/{requestId} {
      // Team-wide read: the Reports "calendar change history" tab (worker-rendered)
      // queries all requests by date and filters client-side, and managers query by
      // managerId — both are collection-wide. Write stays owner/manager-scoped.
      allow read:   if isUserActive();
      allow create: if isUserActive() && createOwnsUserId();
      // Worker edits its own request; managers approve/decline. Update may NOT re-point the
      // record's owner: ownsUserId() only checks the EXISTING owner, so without this pin an owner
      // (or manager) could rewrite userId to a colleague and graft a request onto someone else's
      // calendar history (which the Reports tab queries by userId). The .get() form tolerates a
      // legacy doc predating the userId field, matching the pin on work_sessions/break_sessions/
      // work_hours. Split from delete because a delete carries no request.resource to compare.
      allow update: if isUserActive() && (ownsUserId() || isManagerOrAdmin())
                    && request.resource.data.get('userId', '') == resource.data.get('userId', '');
      allow delete: if isUserActive() && (ownsUserId() || isManagerOrAdmin());
    }

    // ---- REQUEST NOTIFICATIONS (recipient = owner) --------------------------
    // Created BY a worker/system FOR a manager (recipientId). The recipient reads
    // and updates (mark read); any active user may create one to notify a manager.
    //
    // CREATE was previously `if isUserActive()` with NO shape check — yet every doc
    // created here fires a Cloud Function that pushes an OS notification to the
    // recipient's devices. That conflated "may write a doc" with "may ring someone's
    // phone". The tightened create rule below cannot rate-limit (rules can't count over
    // time — that needs a sender-side throttle), but it does:
    //   * require a non-empty string recipientId (no malformed/auto-display abuse),
    //   * bind provenance to the caller — the doc must stamp the caller's uid as either
    //     `createdBy` (comment/approval writers) OR `userId` (completion/time-extension
    //     writers), so a user cannot forge a notification "from" someone else,
    //   * require it start unread, and
    //   * clamp the only free-form, user-authored field (`commentText`) that crosses the
    //     app boundary onto a lockscreen, so it can't carry an oversized/multiline payload.
    // All four current client write-sites satisfy this (audited 2026-06-22).
    match /request_notifications/{notifId} {
      allow read:   if isUserActive() && resource.data.recipientId == request.auth.uid;
      allow create: if isUserActive()
                    && request.resource.data.recipientId is string
                    && request.resource.data.recipientId.size() > 0
                    && (request.resource.data.get('createdBy', '') == request.auth.uid ||
                        request.resource.data.get('userId', '') == request.auth.uid)
                    && request.resource.data.get('isRead', false) == false
                    && (!('commentText' in request.resource.data) ||
                        (request.resource.data.commentText is string &&
                         request.resource.data.commentText.size() <= 2000));
      allow update: if isUserActive() && resource.data.recipientId == request.auth.uid;
      allow delete: if isUserActive() &&
                    (resource.data.recipientId == request.auth.uid || isManagerOrAdmin());
    }

    // ---- TASK TEMPLATES -----------------------------------------------------
    // Two kinds, told apart by `scope`:
    //   * 'team'     — the shared, curated library ("how we do recurring jobs"). Created by an
    //                  ADMIN; edited/deleted by an admin OR the original creator (so a manager who
    //                  built the team set, e.g. the piro/kostiumai templates, keeps maintaining it
    //                  without being locked out). Legacy templates written before `scope` existed
    //                  carry NO field and are read as 'team' via .get('scope','team').
    //   * 'personal' — one user's private quick-start templates: created/edited/deleted by their
    //                  owner only.
    // READ stays team-wide, exactly as it always was. Personal-template privacy is a UI concern
    // (the client only surfaces a user's own personal ones), NOT a hard boundary — this is a small
    // trusted team, and a per-scope read rule would force a production backfill of the legacy docs
    // (which have no `scope` field, so a `where('scope','==','team')` query would silently drop
    // them) purely to keep them queryable. Not worth the migration risk for this threat model.
    match /task_templates/{templateId} {
      function tmplScope(data) { return data.get('scope', 'team'); }

      allow read: if isUserActive();

      // Create: anyone active may add a PERSONAL template (stamped with their own uid); only an
      // admin may create a TEAM (shared) template.
      allow create: if isUserActive()
                    && request.resource.data.createdBy == request.auth.uid
                    && ( tmplScope(request.resource.data) == 'personal'
                         || (tmplScope(request.resource.data) == 'team' && isAdmin()) );

      // Update/Delete: a personal template only by its owner; a team template by an admin OR its
      // creator. Ownership and scope are immutable on a normal edit — only an admin may re-scope
      // (promote a personal template to team / demote one) or this would be a self-promotion hole.
      allow update: if isUserActive()
                    && request.resource.data.createdBy == resource.data.createdBy
                    && ( isAdmin() || tmplScope(request.resource.data) == tmplScope(resource.data) )
                    && ( (tmplScope(resource.data) == 'personal' && resource.data.createdBy == request.auth.uid)
                         || (tmplScope(resource.data) == 'team' && (isAdmin() || resource.data.createdBy == request.auth.uid)) );
      allow delete: if isUserActive()
                    && ( (tmplScope(resource.data) == 'personal' && resource.data.createdBy == request.auth.uid)
                         || (tmplScope(resource.data) == 'team' && (isAdmin() || resource.data.createdBy == request.auth.uid)) );
    }

    // ---- USER SETTINGS (doc id == owner uid) --------------------------------
    match /user_settings/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ---- FCM TOKENS (doc id == owner uid) -----------------------------------
    // Each user stores their own device push tokens (fcm_tokens/{uid} = { tokens: [] }).
    // Only the owner reads/writes; the Cloud Functions sender reads via the admin SDK
    // (which bypasses rules), so no cross-user read is ever needed here.
    match /fcm_tokens/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ---- ERROR LOGS (durable crash log) -------------------------------------
    // Any authenticated user may APPEND a crash report (kept permissive so a broken
    // session can still record its failure); only managers/admins may read them.
    // Entries are immutable; only admins may clear them.
    //
    // CREATE shape guards (full-sweep L2): the client (errorLog.js) clamps message<=2000 and
    // stack/componentStack<=8000, but leaves url/userAgent UNbounded — so a compromised client
    // could flood the manager-visible log with arbitrarily large strings. The bounds below sit
    // ABOVE the client clamps so every legitimate append passes unchanged; they only reject the
    // absurd/oversized payloads corruption produces (the request_notifications/decision_log idiom:
    // each field is checked only when PRESENT). userId must be the caller's own uid OR null — the
    // null branch is REQUIRED: errorLog.js writes userId=null when auth is not ready, which is the
    // earliest-crash case the durable log exists to capture, so pinning to uid alone would silently
    // drop the most important reports. Rules cannot rate-limit (no cross-write counting).
    match /error_logs/{logId} {
      allow create: if isAuthenticated()
                    && (!('message' in request.resource.data) ||
                        (request.resource.data.message is string && request.resource.data.message.size() <= 4000))
                    && (!('stack' in request.resource.data) ||
                        (request.resource.data.stack is string && request.resource.data.stack.size() <= 16000))
                    && (!('componentStack' in request.resource.data) ||
                        (request.resource.data.componentStack is string && request.resource.data.componentStack.size() <= 16000))
                    && (!('url' in request.resource.data) ||
                        (request.resource.data.url is string && request.resource.data.url.size() <= 4000))
                    && (!('userAgent' in request.resource.data) ||
                        (request.resource.data.userAgent is string && request.resource.data.userAgent.size() <= 1000))
                    && (!('source' in request.resource.data) ||
                        (request.resource.data.source is string && request.resource.data.source.size() <= 200))
                    && (request.resource.data.get('userId', null) == null ||
                        request.resource.data.userId == request.auth.uid);
      allow read:   if isManagerOrAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ---- DECISION LOG (AI-native command audit / event spine) ---------------
    // Append-only audit of every consequential command run through the command layer (ADR 0015):
    // who decided (actorType/actorId/actorName), what command against which target, why, and a
    // compact before/after. This is the seam that makes an action — human OR agent — attributable
    // and reversible, and the surface an analysis agent reads to reconstruct events.
    //
    // CREATE: any active user may APPEND, but ONLY as a HUMAN acting as themselves — the doc must
    //   stamp the caller's uid as `actorId` AND declare `actorType:'human'`. Pinning the TYPE (not
    //   just the id) is what stops a human from LAUNDERING a decision as if an AI agent or system job
    //   made it — the attribution boundary ADR 0015 exists to harden. A non-human commit (agent/
    //   system) runs server-side via the admin SDK, which bypasses these rules and stamps its own
    //   actorType. Minimal, permissive shape guards (the request_notifications idiom) keep the audit
    //   spine from being poisoned by a malformed/oversized free-form entry; the appender's payload
    //   passes them unchanged (a null `reason` is tolerated; an absent field defaults-passes).
    // UPDATE: false — entries are IMMUTABLE. The doc id is the command's idempotency key, so a
    //   retried command re-issues setDoc against the same id, which evaluates as an update and is
    //   DENIED here; the client appender swallows that denial (best-effort), leaving the original
    //   entry intact rather than duplicating it.
    // READ: managers/admins, so the audit trail is visible in-app. DELETE: admin only (log hygiene).
    match /decision_log/{opId} {
      allow create: if isUserActive()
                    && request.resource.data.get('actorId', '') == request.auth.uid
                    && request.resource.data.get('actorType', '') == 'human'
                    && request.resource.data.get('command', '') is string
                    && request.resource.data.get('command', '').size() > 0
                    && request.resource.data.get('mode', '') is string
                    && (!('reason' in request.resource.data) ||
                        request.resource.data.reason == null ||
                        (request.resource.data.reason is string &&
                         request.resource.data.reason.size() <= 2000));
      allow read:   if isManagerOrAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ---- INTEGRITY REPORTS (durability monitor output) ----------------------
    // The scheduled integrity-scan Cloud Function (admin SDK) writes one report doc here per run
    // (integrity_reports/{YYYY-MM-DD}) plus a rolling baseline (integrity_reports/_counts): anomaly
    // counts + a sudden-volume-drop canary that signals a possible mass-delete / wipe. Read by
    // managers/admins so the safety net is visible in-app; no CLIENT may write — only the admin SDK,
    // which bypasses rules. Recovery procedure: docs/runbooks/firestore-backup-recovery.md.
    match /integrity_reports/{reportId} {
      allow read:  if isManagerOrAdmin();
      allow write: if false;
    }

    // ---- SYSTEM CONFIG (AI-agent kill-switch + future global toggles) --------
    // system_config/agents = { enabled: boolean, updatedAt, updatedBy }: the AI-agent KILL-SWITCH
    // (ADR 0015) — a single global brake. The command kernel mirrors this flag into memory and
    // refuses EVERY agent command the instant it is engaged, so EVERY active session must be able to
    // READ it (it carries no sensitive data — just a boolean toggle). CREATE/UPDATE (engaging or
    // releasing the brake) is an ADMIN-only privileged safety action; the write must carry a boolean
    // `enabled` (present + typed) so a malformed flag can't silently disable the brake. DELETE is
    // explicitly forbidden (the flag is a permanent control, never removed) — split out from the
    // create/update grant so a future refactor of the shape guard can't accidentally permit it. The
    // future server-side agent surface reads this same doc and fails CLOSED.
    match /system_config/{docId} {
      allow read:          if isUserActive();
      allow create, update: if isAdmin() && request.resource.data.enabled is bool;
      allow delete:        if false;
    }
  }
}
