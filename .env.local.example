# ─────────────────────────────────────────────────────────────────────────────
# .env.local.example — template for local environment variables.
#
# Copy this file to `.env.local` (which is gitignored via the `*.local` rule) and
# fill in the values. NEVER commit real credentials — this repo is PUBLIC.
#
#   cp .env.local.example .env.local
#
# ─────────────────────────────────────────────────────────────────────────────

# Firebase config override (optional in dev — src/firebase.js falls back to the
# built-in `darbo-planavimas` config when these are unset, so local dev talks to
# the real project unless you point it elsewhere).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

# ── DEV-only test login (visual QA) ──────────────────────────────────────────
# Pre-fills the dev-only email/password sign-in panel on the Login page so a QA
# session can authenticate without the Google popup. The panel ONLY renders in a
# dev build (`import.meta.env.DEV`) — it is dead-code-eliminated from production.
# Requires the one-time setup in docs/runbooks/visual-qa-test-account.md
# (Email/Password provider enabled + a test user seeded role=admin, isTest=true).
VITE_DEV_LOGIN_EMAIL=
VITE_DEV_LOGIN_PASSWORD=
